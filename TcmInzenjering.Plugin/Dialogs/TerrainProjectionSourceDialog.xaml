<Window x:Class="TcmInzenjering.Plugin.Dialogs.TerrainProjectionSourceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Projekcija — izbor terena"
        Width="460"
        SizeToContent="Height"
        MinHeight="280"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="180"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,6"
               Text="Izaberite snimljeni teren za projekciju ose"/>
    <TextBlock Grid.Row="1" TextWrapping="Wrap" Foreground="#555" Margin="0,0,0,10"
               Text="Jedan klik u crtezu na 3DFACE / border dovoljan je — odmah se zna kom modelu pripada."/>

    <ListBox Grid.Row="2" x:Name="TerrainList" Margin="0,0,0,12"
             MouseDoubleClick="OnListDoubleClick"/>

    <TextBlock Grid.Row="3" x:Name="EmptyHint" Visibility="Collapsed" TextWrapping="Wrap"
               Foreground="#8A6D00" Background="#FFF3CD" Padding="8,6" Margin="0,0,0,12"
               Text="Nema snimljenih terena. Prvo TCMTERFACE (3DFACE teren) ili izaberite objekat u crtežu."/>

    <StackPanel Grid.Row="4">
      <Button Content="Izaberi u crtezu…" Height="30" Margin="0,0,0,10"
              Click="OnPickInDrawing"
              ToolTip="Privremeno se vracate u crtez — kliknite jedan element terena"/>
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
        <Button Content="OK" Width="96" Height="28" IsDefault="True" Click="OnOk" Margin="0,0,8,0"/>
        <Button Content="Odustani" Width="96" Height="28" IsCancel="True" Click="OnCancel"/>
      </StackPanel>
    </StackPanel>
  </Grid>
</Window>
