<Window x:Class="TcmInzenjering.Plugin.Dialogs.UpdateAvailableDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TCM-ROADS — Nadogradnja"
        SizeToContent="Height"
        Width="440"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock x:Name="VersionText" TextWrapping="Wrap" FontSize="13" Margin="0,0,0,10"/>
    <TextBlock x:Name="NotesText" Grid.Row="1" TextWrapping="Wrap" Margin="0,0,0,10"
               Foreground="#444" Visibility="Collapsed" MaxHeight="120" TextTrimming="CharacterEllipsis"/>
    <TextBlock Grid.Row="2" TextWrapping="Wrap" Margin="0,0,0,12" Foreground="#333"
               Text="Preuzimanje ide u posebnom prozoru — AutoCAD možete nastaviti da koristite. Kad zatvorite AutoCAD, instalacija se automatski završava."/>

    <CheckBox x:Name="CheckOnStartupBox" Grid.Row="3" Margin="0,0,0,16"
              Content="Proveravaj nadogradnju pri startu AutoCAD-a"
              ToolTip="Isključite da se pri sledećem startu ne proverava nova verzija. Možete uvek TCMUPDATE."/>

    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
      <Button Content="Preuzmi" Width="100" Height="28" Margin="0,0,8,0" IsDefault="True" Click="OnYes"/>
      <Button Content="Ne sada" Width="100" Height="28" IsCancel="True" Click="OnNo"/>
    </StackPanel>
  </Grid>
</Window>
