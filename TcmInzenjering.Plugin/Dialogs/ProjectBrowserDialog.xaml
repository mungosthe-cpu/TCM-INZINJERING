<Window x:Class="TcmInzenjering.Plugin.Dialogs.ProjectBrowserDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TCM-ROADS — Projekat"
        Height="640"
        Width="880"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        MinHeight="480"
        MinWidth="760"
        ShowInTaskbar="False"
        Background="#F3F4F6">
  <Window.Resources>
    <SolidColorBrush x:Key="CardBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#E5E7EB"/>
    <SolidColorBrush x:Key="TextBrush" Color="#111827"/>
    <SolidColorBrush x:Key="MutedBrush" Color="#6B7280"/>
    <SolidColorBrush x:Key="PrimaryBrush" Color="#2563EB"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#1D4ED8"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#16A34A"/>
    <SolidColorBrush x:Key="DangerBrush" Color="#DC2626"/>

    <Style x:Key="CardStyle" TargetType="Border">
      <Setter Property="Background" Value="{StaticResource CardBrush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="10"/>
    </Style>

    <Style x:Key="CardHeaderText" TargetType="TextBlock">
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="IconText" TargetType="TextBlock">
      <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="BaseButton" TargetType="Button">
      <Setter Property="Height" Value="34"/>
      <Setter Property="Padding" Value="14,0"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
      <Setter Property="Background" Value="{StaticResource CardBrush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="8"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#F9FAFB"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.5"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
      <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="8"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{StaticResource PrimaryHoverBrush}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="DangerOutlineButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
      <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
      <Setter Property="BorderBrush" Value="#FCA5A5"/>
    </Style>

    <Style TargetType="ComboBox">
      <Setter Property="Height" Value="34"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="Padding" Value="10,0"/>
      <Setter Property="FontSize" Value="13"/>
    </Style>

    <Style TargetType="TextBox">
      <Setter Property="Height" Value="34"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="Padding" Value="8,0"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
    </Style>

    <Style TargetType="TabControl">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="0"/>
    </Style>

    <Style TargetType="TabItem">
      <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TabItem">
            <Border Background="Transparent" Padding="12,7,12,5">
              <StackPanel>
                <ContentPresenter ContentSource="Header" HorizontalAlignment="Center"/>
                <Border x:Name="Underline" Height="2" Margin="0,5,0,0"
                        Background="Transparent" CornerRadius="1"/>
              </StackPanel>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="Underline" Property="Background" Value="{StaticResource SuccessBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style TargetType="ListBox">
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
      <Setter Property="Background" Value="{StaticResource CardBrush}"/>
      <Setter Property="Padding" Value="4"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ListBox">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="8"
                    Padding="{TemplateBinding Padding}">
              <Grid>
                <ScrollViewer Focusable="False">
                  <ItemsPresenter/>
                </ScrollViewer>
                <StackPanel x:Name="EmptyState"
                            Visibility="Collapsed"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                  <TextBlock Text="&#xE7B8;"
                             FontFamily="Segoe MDL2 Assets"
                             FontSize="34"
                             Foreground="#9CA3AF"
                             HorizontalAlignment="Center"
                             Margin="0,0,0,10"/>
                  <TextBlock Text="Lista je prazna"
                             FontSize="14"
                             FontWeight="SemiBold"
                             Foreground="{StaticResource MutedBrush}"
                             HorizontalAlignment="Center"/>
                  <TextBlock Text="Izaberite karticu za prikaz dostupnih elemenata."
                             FontSize="12"
                             Foreground="#9CA3AF"
                             HorizontalAlignment="Center"
                             Margin="0,4,0,0"/>
                </StackPanel>
              </Grid>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="HasItems" Value="False">
                <Setter TargetName="EmptyState" Property="Visibility" Value="Visible"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style TargetType="ListBoxItem">
      <Setter Property="Padding" Value="8,5"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ListBoxItem">
            <Border x:Name="Bd" Background="Transparent" CornerRadius="6"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#F3F4F6"/>
              </Trigger>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="#DBEAFE"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style TargetType="TreeView">
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Background" Value="Transparent"/>
    </Style>
  </Window.Resources>

  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Zaglavlje: projekat + akcije -->
    <Grid Grid.Row="0" Margin="0,0,0,12">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <TextBlock Text="Projekat:" VerticalAlignment="Center" Margin="0,0,10,0"
                 FontSize="13" Foreground="{StaticResource TextBrush}"/>
      <ComboBox Grid.Column="1" x:Name="ProjectBox" Margin="0,0,10,0"
                SelectionChanged="OnProjectChanged"/>
      <Button Grid.Column="2" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0" Click="OnNewProject">
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="&#xE710;" Style="{StaticResource IconText}" Foreground="White"
                     FontSize="12" Margin="0,0,7,0"/>
          <TextBlock Text="Novi" VerticalAlignment="Center"/>
        </StackPanel>
      </Button>
      <Button Grid.Column="3" Style="{StaticResource BaseButton}" Margin="0,0,8,0" Click="OnRenameProject">
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="&#xE70F;" Style="{StaticResource IconText}" FontSize="12" Margin="0,0,7,0"/>
          <TextBlock Text="Preimenuj" VerticalAlignment="Center"/>
        </StackPanel>
      </Button>
      <Button Grid.Column="4" Style="{StaticResource DangerOutlineButton}" Click="OnDeleteProject">
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="&#xE74D;" Style="{StaticResource IconText}"
                     Foreground="{StaticResource DangerBrush}" FontSize="12" Margin="0,0,7,0"/>
          <TextBlock Text="Obrisi" VerticalAlignment="Center"/>
        </StackPanel>
      </Button>
    </Grid>

    <!-- Dve kartice -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="1.15*"/>
        <ColumnDefinition Width="14"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <Border Style="{StaticResource CardStyle}" Padding="14">
        <DockPanel>
          <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="&#xE8F1;" Style="{StaticResource IconText}"
                       Foreground="{StaticResource PrimaryBrush}" Margin="0,0,8,0"/>
            <TextBlock Text="Elementi u projektu" Style="{StaticResource CardHeaderText}"/>
          </StackPanel>
          <StackPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
            <Button Style="{StaticResource BaseButton}" Margin="0,0,0,8"
                    HorizontalContentAlignment="Left"
                    Click="OnPreviewTerrainPoints"
                    ToolTip="Privremeno prikazuje tacke izabranog terena i debelu granicu skupa; klik u crtezu vraca ovaj prozor.">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE7B3;" Style="{StaticResource IconText}"
                           Foreground="{StaticResource PrimaryBrush}" Margin="0,0,8,0"/>
                <TextBlock Text="Prikazi u crtezu" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
            <Button Style="{StaticResource BaseButton}" Margin="0,0,0,8"
                    Click="OnApplyBoundaryToDrawing"
                    ToolTip="Vraca izabranu granicu (sa !) u crtez i TIN.">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE70F;" Style="{StaticResource IconText}"
                           Foreground="#7C3AED" Margin="0,0,8,0"/>
                <TextBlock Text="Primeni na crtez" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
            <Button Style="{StaticResource BaseButton}"
                    Click="OnExcludeBoundaryFromDrawing"
                    ToolTip="Uklanja granicu iz crteza (ostaje u projektu sa !), TIN bez granice.">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xF003;" Style="{StaticResource IconText}"
                           Foreground="{StaticResource SuccessBrush}" Margin="0,0,8,0"/>
                <TextBlock Text="Izuzmi iz crteza" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
          </StackPanel>
          <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                  CornerRadius="8" Padding="6">
            <TreeView x:Name="ProjectTree" MouseDoubleClick="OnProjectTreeDoubleClick"
                      ToolTip="Dupli klik: Tacke = uredjivanje; Granica sa ! = primeni na crtez."/>
          </Border>
        </DockPanel>
      </Border>

      <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="14">
        <DockPanel>
          <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
            <TextBlock Text="&#xE8A9;" Style="{StaticResource IconText}"
                       Foreground="{StaticResource PrimaryBrush}" Margin="0,0,8,0"/>
            <TextBlock Text="Dostupno u crtezu" Style="{StaticResource CardHeaderText}"/>
          </StackPanel>
          <StackPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
            <Button Style="{StaticResource BaseButton}" Margin="0,0,0,8" Click="OnAddSelected">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE710;" Style="{StaticResource IconText}"
                           Foreground="{StaticResource SuccessBrush}" FontSize="12" Margin="0,0,8,0"/>
                <TextBlock Text="Dodaj izabrano u projekat" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
            <Button Style="{StaticResource BaseButton}" Click="OnRemoveFromProject">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE738;" Style="{StaticResource IconText}"
                           Foreground="{StaticResource DangerBrush}" FontSize="12" Margin="0,0,8,0"/>
                <TextBlock Text="Ukloni iz projekta" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
          </StackPanel>
          <TabControl>
            <TabItem Header="Tereni">
              <ListBox x:Name="TerrainList" SelectionMode="Extended" Margin="0,8,0,0"
                       MouseDoubleClick="OnAvailableTerrainDoubleClick"
                       ToolTip="Dupli klik = privremeni prikaz tacaka i granice terena u crtezu."/>
            </TabItem>
            <TabItem Header="Osovine">
              <ListBox x:Name="AxisList" SelectionMode="Extended" Margin="0,8,0,0"/>
            </TabItem>
            <TabItem Header="Poduzni profili">
              <ListBox x:Name="ProfileList" SelectionMode="Extended" Margin="0,8,0,0"/>
            </TabItem>
            <TabItem Header="Tacke">
              <ListBox x:Name="PointsList" SelectionMode="Extended" Margin="0,8,0,0"
                       ToolTip="Imenovani skupovi tacaka (npr. Teren_1, Teren_1_Granica). Dupli klik u stablu projekta otvara uredjivanje."/>
            </TabItem>
            <TabItem Header="Granice">
              <ListBox x:Name="BoundaryList" SelectionMode="Extended" Margin="0,8,0,0"
                       ToolTip="Granice terena iz TCMTERBOUND (lejer TCM_TER_GRANICA)."/>
            </TabItem>
          </TabControl>
        </DockPanel>
      </Border>
    </Grid>

    <!-- Footer -->
    <DockPanel Grid.Row="2" Margin="0,14,0,0">
      <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
        <TextBlock Text="Folder:" VerticalAlignment="Center" Margin="0,0,8,0"
                   FontSize="13" Foreground="{StaticResource TextBrush}"/>
        <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1" CornerRadius="8" Padding="10,0" Height="34">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="&#xE8B7;" Style="{StaticResource IconText}"
                       Foreground="#F59E0B" Margin="0,0,8,0"/>
            <TextBox x:Name="FolderBox" Width="240" BorderThickness="0"
                     Background="Transparent" IsReadOnly="True"
                     VerticalAlignment="Center"/>
          </StackPanel>
        </Border>
        <Button Content="..." Width="38" Style="{StaticResource BaseButton}" Margin="8,0,0,0"
                Click="OnPickFolder"
                ToolTip="Folder projekta za snimanje tacaka / izlaza"/>
      </StackPanel>
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
        <Button Style="{StaticResource PrimaryButton}" Width="120" Margin="0,0,10,0" Click="OnSave">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="&#xE74E;" Style="{StaticResource IconText}" Foreground="White"
                       FontSize="12" Margin="0,0,8,0"/>
            <TextBlock Text="Sacuvaj" VerticalAlignment="Center"/>
          </StackPanel>
        </Button>
        <Button Style="{StaticResource BaseButton}" Width="120" IsCancel="True" IsDefault="True" Click="OnClose">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="&#xE711;" Style="{StaticResource IconText}" FontSize="12" Margin="0,0,8,0"/>
            <TextBlock Text="Zatvori" VerticalAlignment="Center"/>
          </StackPanel>
        </Button>
      </StackPanel>
    </DockPanel>
  </Grid>
</Window>
