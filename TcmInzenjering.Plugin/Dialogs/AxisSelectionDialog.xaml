<Window x:Class="TcmInzenjering.Plugin.Dialogs.AxisSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TCM-ROADS — Izbor osovine"
        Width="470"
        SizeToContent="Height"
        MinHeight="250"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#F5F7FA">
  <Window.Resources>
    <Style TargetType="Button">
      <Setter Property="Height" Value="38"/>
      <Setter Property="Padding" Value="16,0"/>
      <Setter Property="Margin" Value="0,0,8,0"/>
      <Setter Property="FontSize" Value="13"/>
    </Style>
  </Window.Resources>

  <Grid Margin="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Text="Izbor osovine"
               FontSize="21"
               FontWeight="SemiBold"
               Foreground="#173B68"/>
    <TextBlock Grid.Row="1"
               Text="Izaberite osovinu na kojoj želite da izvršite komandu."
               Margin="0,8,0,16"
               Foreground="#52606D"
               TextWrapping="Wrap"/>

    <Border Grid.Row="2"
            Background="White"
            BorderBrush="#D7DEE8"
            BorderThickness="1"
            CornerRadius="7"
            Padding="14"
            Margin="0,0,0,18">
      <StackPanel>
        <TextBlock Text="Osovina" FontWeight="SemiBold" Margin="0,0,0,7"/>
        <ComboBox x:Name="AxisBox"
                  Height="34"
                  FontSize="14"
                  VerticalContentAlignment="Center"/>
        <TextBlock Text="Ako ne znate ime, kliknite „Izaberi u crtežu“ i označite osovinu."
                   Margin="0,8,0,0"
                   Foreground="#6B7785"
                   FontSize="12"
                   TextWrapping="Wrap"/>
      </StackPanel>
    </Border>

    <Grid Grid.Row="3">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <Button Grid.Column="0"
              Content="⌖  Izaberi u crtežu"
              Click="OnPickInDrawing"
              Foreground="#175EA8"/>
      <StackPanel Grid.Column="2" Orientation="Horizontal">
        <Button Content="Otkaži" Click="OnCancel"/>
        <Button Content="Nastavi"
                IsDefault="True"
                Click="OnContinue"
                Background="#1769D2"
                Foreground="White"
                BorderBrush="#1769D2"
                Margin="0"/>
      </StackPanel>
    </Grid>
  </Grid>
</Window>
