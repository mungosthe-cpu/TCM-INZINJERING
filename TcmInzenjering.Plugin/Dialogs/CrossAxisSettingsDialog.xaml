<Window x:Class="TcmInzenjering.Plugin.Dialogs.CrossAxisSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Podešavanja oznaka poprečnih osa i stacionaža"
        Height="560"
        Width="720"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="220"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Column="0" Margin="0,0,12,0">
            <GroupBox Header="Oznake (npr. STA 4)" Padding="10,8,10,10" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <CheckBox x:Name="LabelsEnabledCheck"
                              Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                              Content="Oznake (tekst STA …)"
                              IsChecked="True"
                              Margin="0,0,0,8"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Strana:" VerticalAlignment="Center" Margin="0,0,12,6"/>
                    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,6">
                        <RadioButton x:Name="LabelsLeftRadio" Content="Levo" GroupName="LabelsSide" Margin="0,0,16,0"/>
                        <RadioButton x:Name="LabelsRightRadio" Content="Desno" GroupName="LabelsSide" IsChecked="True"/>
                    </StackPanel>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Odmak X od ose:" VerticalAlignment="Center" Margin="0,0,12,6"/>
                    <Grid Grid.Row="2" Grid.Column="1" Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="30"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="LabelsOffsetXBox" Height="22" VerticalContentAlignment="Center" Margin="0,0,4,0"/>
                        <Button x:Name="PickLabelsOffsetButton"
                                Grid.Column="1"
                                Content="⊕"
                                Height="22"
                                Width="26"
                                Padding="0"
                                ToolTip="Odredi odmak u crtežu"
                                Click="OnPickLabelsOffset"/>
                    </Grid>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Odmak Y od ose:" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <TextBox x:Name="LabelsOffsetYBox" Grid.Row="3" Grid.Column="1" Height="22" VerticalContentAlignment="Center"/>
                </Grid>
            </GroupBox>

            <GroupBox Header="Stacionaža (npr. 0+050.00)" Padding="10,8,10,10" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <CheckBox x:Name="StationsEnabledCheck"
                              Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                              Content="Stacionaža (vrednost 0+…)"
                              IsChecked="True"
                              Margin="0,0,0,8"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Strana:" VerticalAlignment="Center" Margin="0,0,12,6"/>
                    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,6">
                        <RadioButton x:Name="StationsLeftRadio" Content="Levo" GroupName="StationsSide" IsChecked="True"/>
                        <RadioButton x:Name="StationsRightRadio" Content="Desno" GroupName="StationsSide" Margin="16,0,0,0"/>
                    </StackPanel>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Odmak X od ose:" VerticalAlignment="Center" Margin="0,0,12,6"/>
                    <Grid Grid.Row="2" Grid.Column="1" Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="30"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="StationsOffsetXBox" Height="22" VerticalContentAlignment="Center" Margin="0,0,4,0"/>
                        <Button x:Name="PickStationsOffsetButton"
                                Grid.Column="1"
                                Content="⊕"
                                Height="22"
                                Width="26"
                                Padding="0"
                                ToolTip="Odredi odmak u crtežu"
                                Click="OnPickStationsOffset"/>
                    </Grid>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Odmak Y od ose:" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <TextBox x:Name="StationsOffsetYBox" Grid.Row="3" Grid.Column="1" Height="22" VerticalContentAlignment="Center"/>
                </Grid>
            </GroupBox>

            <GroupBox Header="Dužina poprečnih osa (od osovine)" Padding="10,8,10,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <CheckBox x:Name="LengthsEnabledCheck"
                              Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                              Content="Promeni dužinu poprečnih osa"
                              IsChecked="False"
                              Margin="0,0,0,8"/>

                    <TextBlock Grid.Row="1" Grid.Column="0"
                               Text="Levo u odnosu na osovinu:"
                               VerticalAlignment="Center"
                               Margin="0,0,12,6"/>
                    <TextBox x:Name="LeftLengthBox"
                             Grid.Row="1" Grid.Column="1"
                             Height="22"
                             VerticalContentAlignment="Center"
                             Margin="0,0,0,6"/>

                    <TextBlock Grid.Row="2" Grid.Column="0"
                               Text="Desno u odnosu na osovinu:"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"/>
                    <TextBox x:Name="RightLengthBox"
                             Grid.Row="2" Grid.Column="1"
                             Height="22"
                             VerticalContentAlignment="Center"/>
                </Grid>
            </GroupBox>
        </StackPanel>

        <GroupBox Grid.Column="1" Header="Poprečne ose:" Padding="8,8,8,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <CheckBox x:Name="IndividualModeCheck"
                          Grid.Row="0"
                          Content="Pojedinačno"
                          Margin="0,0,0,8"
                          Checked="OnIndividualModeChanged"
                          Unchecked="OnIndividualModeChanged"/>

                <ListBox x:Name="AxisListBox"
                         Grid.Row="1"
                         SelectionMode="Extended"
                         MinHeight="220"
                         Margin="0,0,0,8"
                         SelectionChanged="OnAxisSelectionChanged"
                         DisplayMemberPath="DisplayName"/>

                <Button Grid.Row="2"
                        Content="Poništi selekciju"
                        Height="24"
                        Margin="0,0,0,6"
                        Click="OnClearSelection"/>

                <Button Grid.Row="3"
                        Content="Izaberi u crtežu"
                        Height="24"
                        Click="OnPickAxesInDrawing"/>
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="OK"
                    Width="88"
                    Height="26"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="OnOk"/>
            <Button Content="Cancel"
                    Width="88"
                    Height="26"
                    IsCancel="True"
                    Click="OnCancel"/>
        </StackPanel>
    </Grid>
</Window>
