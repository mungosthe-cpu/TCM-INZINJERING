<Window x:Class="TcmInzenjering.Plugin.Dialogs.CrossAxisSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Podešavanja oznaka poprečnih osa i stacionaža"
        Height="620"
        Width="780"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#F7F8FA">
    <Window.Resources>
        <SolidColorBrush x:Key="Border" Color="#E1E5EA"/>
        <SolidColorBrush x:Key="Blue" Color="#2563B8"/>
        <SolidColorBrush x:Key="Green" Color="#239B68"/>
        <SolidColorBrush x:Key="Purple" Color="#7650B5"/>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14"/>
        </Style>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="3"/>
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="8,5"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="235"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Column="0" Margin="16,14,12,12">
            <Border Style="{StaticResource Card}" Margin="0,0,0,10">
              <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <Border Background="#EDF4FF" CornerRadius="12" Width="24" Height="24" Margin="0,0,8,0">
                        <TextBlock Text="◇" Foreground="{StaticResource Blue}" FontSize="16"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="1." Foreground="{StaticResource Blue}" FontWeight="Bold"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="OZNAKE (npr. STA 4)" Foreground="{StaticResource Blue}"
                               FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <CheckBox x:Name="LabelsEnabledCheck"
                              Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                              Content="Prikaži oznake (tekst: STA …)"
                              IsChecked="True"
                              Margin="0,0,0,8"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Strana:" VerticalAlignment="Center" Margin="0,0,12,6"/>
                    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,6">
                        <RadioButton x:Name="LabelsLeftRadio" Content="Levo" GroupName="LabelsSide" Margin="0,0,16,0"/>
                        <RadioButton x:Name="LabelsRightRadio" Content="Desno" GroupName="LabelsSide" IsChecked="True"/>
                    </StackPanel>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Odmak X od ose:" VerticalAlignment="Center" Margin="0,0,12,7"/>
                    <Grid Grid.Row="2" Grid.Column="1" Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="38"/>
                            <ColumnDefinition Width="28"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="LabelsOffsetXBox" Margin="0,0,7,0"/>
                        <Button x:Name="PickLabelsOffsetButton"
                                Grid.Column="1"
                                Content="◎"
                                Height="30"
                                Width="34"
                                Padding="0"
                                ToolTip="Odredi odmak u crtežu"
                                Click="OnPickLabelsOffset"/>
                        <TextBlock Grid.Column="2" Text="m" VerticalAlignment="Center" Margin="7,0,0,0"/>
                    </Grid>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Odmak Y od ose:" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <Grid Grid.Row="3" Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="28"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="LabelsOffsetYBox"/>
                        <TextBlock Grid.Column="1" Text="m" VerticalAlignment="Center" Margin="7,0,0,0"/>
                    </Grid>
                </Grid>
              </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,0,0,10">
              <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <Border Background="#ECF9F2" CornerRadius="12" Width="24" Height="24" Margin="0,0,8,0">
                        <TextBlock Text="⚑" Foreground="{StaticResource Green}" FontSize="14"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="2." Foreground="{StaticResource Green}" FontWeight="Bold"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="STACIONAŽA (npr. 0+050.00)" Foreground="{StaticResource Green}"
                               FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <CheckBox x:Name="StationsEnabledCheck"
                              Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                              Content="Prikaži stacionažu (vrednost 0+…)"
                              IsChecked="True"
                              Margin="0,0,0,8"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Strana:" VerticalAlignment="Center" Margin="0,0,12,6"/>
                    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,6">
                        <RadioButton x:Name="StationsLeftRadio" Content="Levo" GroupName="StationsSide" IsChecked="True"/>
                        <RadioButton x:Name="StationsRightRadio" Content="Desno" GroupName="StationsSide" Margin="16,0,0,0"/>
                    </StackPanel>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Odmak X od ose:" VerticalAlignment="Center" Margin="0,0,12,6"/>
                    <Grid Grid.Row="2" Grid.Column="1" Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="38"/>
                            <ColumnDefinition Width="28"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="StationsOffsetXBox" Margin="0,0,7,0"/>
                        <Button x:Name="PickStationsOffsetButton"
                                Grid.Column="1"
                                Content="◎"
                                Height="30"
                                Width="34"
                                Padding="0"
                                ToolTip="Odredi odmak u crtežu"
                                Click="OnPickStationsOffset"/>
                        <TextBlock Grid.Column="2" Text="m" VerticalAlignment="Center" Margin="7,0,0,0"/>
                    </Grid>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Odmak Y od ose:" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <Grid Grid.Row="3" Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="28"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="StationsOffsetYBox"/>
                        <TextBlock Grid.Column="1" Text="m" VerticalAlignment="Center" Margin="7,0,0,0"/>
                    </Grid>
                </Grid>
              </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
              <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <Border Background="#F2EDFB" CornerRadius="12" Width="24" Height="24" Margin="0,0,8,0">
                        <TextBlock Text="⌇" Foreground="{StaticResource Purple}" FontSize="16"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="3." Foreground="{StaticResource Purple}" FontWeight="Bold"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="DUŽINA POPREČNIH OSA (od osovine)" Foreground="{StaticResource Purple}"
                               FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <CheckBox x:Name="LengthsEnabledCheck"
                              Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                              Content="Promeni dužinu poprečnih osa"
                              IsChecked="False"
                              Margin="0,0,0,8"/>

                    <TextBlock Grid.Row="1" Grid.Column="0"
                               Text="Levo u odnosu na osovinu:"
                               VerticalAlignment="Center"
                               Margin="0,0,12,6"/>
                    <Grid Grid.Row="1" Grid.Column="1" Margin="0,0,0,7">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="28"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="LeftLengthBox"/>
                        <TextBlock Grid.Column="1" Text="m" VerticalAlignment="Center" Margin="7,0,0,0"/>
                    </Grid>

                    <TextBlock Grid.Row="2" Grid.Column="0"
                               Text="Desno u odnosu na osovinu:"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"/>
                    <Grid Grid.Row="2" Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="28"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="RightLengthBox"/>
                        <TextBlock Grid.Column="1" Text="m" VerticalAlignment="Center" Margin="7,0,0,0"/>
                    </Grid>
                </Grid>
              </StackPanel>
            </Border>
        </StackPanel>

        <Border Grid.Column="1" Style="{StaticResource Card}" Margin="0,14,16,12">
          <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Border Background="#EDF4FF" CornerRadius="12" Width="24" Height="24" Margin="0,0,8,0">
                    <TextBlock Text="◫" Foreground="{StaticResource Blue}" FontSize="15"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="POPREČNE OSE" Foreground="{StaticResource Blue}"
                           FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <CheckBox x:Name="IndividualModeCheck"
                          Grid.Row="0"
                          Content="Pojedinačno"
                          Margin="0,0,0,8"
                          Checked="OnIndividualModeChanged"
                          Unchecked="OnIndividualModeChanged"/>

                <ListBox x:Name="AxisListBox"
                         Grid.Row="1"
                         SelectionMode="Extended"
                         MinHeight="220"
                         Margin="0,0,0,8"
                         SelectionChanged="OnAxisSelectionChanged"
                         DisplayMemberPath="DisplayName"/>

                <Button Grid.Row="2"
                        Content="🗑  Poništi selekciju"
                        Style="{StaticResource ActionButton}"
                        Margin="0,0,0,6"
                        Click="OnClearSelection"/>

                <Button Grid.Row="3"
                        Content="▧  Izaberi u crtežu"
                        Style="{StaticResource ActionButton}"
                        Click="OnPickAxesInDrawing"/>
            </Grid>
          </Grid>
        </Border>

        <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                Background="White" BorderBrush="{StaticResource Border}"
                BorderThickness="0,1,0,0" Padding="16,11">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="✓   OK" Width="125" Height="38" Margin="0,0,10,0"
                        Background="#1769D2" Foreground="White" BorderBrush="#1769D2"
                        FontWeight="SemiBold" IsDefault="True" Click="OnOk"/>
                <Button Content="✕   Cancel" Width="125" Height="38"
                        Background="White" BorderBrush="{StaticResource Border}"
                        IsCancel="True" Click="OnCancel"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
