<Window x:Class="TcmInzenjering.Plugin.Dialogs.SelectColorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Color"
        Height="420"
        Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" Text="Index Color" FontWeight="SemiBold" Margin="0,0,0,8"/>

    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
      <StackPanel>
        <TextBlock Text="Standard colors" Margin="0,0,0,6" Foreground="#555"/>
        <UniformGrid x:Name="StandardGrid" Columns="7" Margin="0,0,0,12"/>
        <TextBlock Text="Index colors" Margin="0,0,0,6" Foreground="#555"/>
        <UniformGrid x:Name="IndexGrid" Columns="10"/>
      </StackPanel>
    </ScrollViewer>

    <Grid Grid.Row="2" Margin="0,12,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <TextBlock Text="Color:" VerticalAlignment="Center" Margin="0,0,8,0"/>
      <TextBox Grid.Column="1" x:Name="ColorNameBox" Height="26" IsReadOnly="True" Margin="0,0,8,0"/>
      <Border Grid.Column="2" x:Name="PreviewBorder" Width="56" Height="26"
              BorderBrush="Gray" BorderThickness="1" Margin="0,0,8,0"/>
      <StackPanel Grid.Column="3">
        <Button Content="ByLayer" Width="80" Height="24" Margin="0,0,0,4" Click="OnByLayer"/>
        <Button Content="ByBlock" Width="80" Height="24" Click="OnByBlock"/>
      </StackPanel>
    </Grid>

    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
      <Button Content="OK" Width="88" Height="28" IsDefault="True" Click="OnOk" Margin="0,0,8,0"/>
      <Button Content="Cancel" Width="88" Height="28" IsCancel="True" Click="OnCancel"/>
    </StackPanel>
  </Grid>
</Window>
