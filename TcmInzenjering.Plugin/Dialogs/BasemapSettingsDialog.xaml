<Window x:Class="TcmInzenjering.Plugin.Dialogs.BasemapSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Georeferencirana podloga — Teren"
        Width="560" Height="640"
        MinWidth="520" MinHeight="580"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False"
        Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
  <Grid Margin="14">
    <Grid.RowDefinitions>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel>
        <TextBlock TextWrapping="Wrap" Foreground="#555" Margin="0,0,0,10"
                   Text="Ubacuje satelitsku / ortofoto podlogu u georeferenciran crtez. Google Earth tile-ovi se ne preuzimaju — koristi se Autodesk/Esri ili legalan WMS/ArcGIS/GeoTIFF."/>

        <Border BorderBrush="#CCC" BorderThickness="1" Background="#FFF8E1" Padding="8" Margin="0,0,0,12" CornerRadius="3">
          <StackPanel>
            <TextBlock x:Name="GeoStatusText" TextWrapping="Wrap" FontWeight="SemiBold"/>
            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
              <Button Content="Geolokacija iz X/Y (auto)" Width="170" Height="26" Click="OnAutoGeo" Margin="0,0,8,0"
                      FontWeight="SemiBold"
                      ToolTip="Automatski postavlja geolokaciju iz zvanicnih Gauss-Krüger koordinata crteza (zona iz Y prefiksa)"/>
              <Button Content="Podesi geolokaciju…" Width="140" Height="26" Click="OnAssignGeo" Margin="0,0,8,0"
                      ToolTip="Pokrece GEOGRAPHICLOCATION"/>
              <Button Content="Dodeli CRS…" Width="100" Height="26" Click="OnAssignCrs"
                      ToolTip="Pokrece MAPCSASSIGN (Civil/Map)"/>
            </StackPanel>
          </StackPanel>
        </Border>

        <GroupBox Header="Nacin rada" Padding="10" Margin="0,0,0,10">
          <StackPanel>
            <RadioButton x:Name="ModeAutodeskRadio" Content="Autodesk online mapa (Esri / Bing)"
                         IsChecked="True" Margin="0,0,0,6" Checked="OnModeChanged"/>
            <TextBlock Text="Prikaz uzivo (GEOMAP) ili ugradjena slika u DWG (GEOMAPIMAGE). Zahteva Autodesk nalog."
                       TextWrapping="Wrap" Foreground="#666" Margin="22,0,0,10" FontSize="11"/>
            <RadioButton x:Name="ModeExternalRadio" Content="Nezavisna podloga (WMS / ArcGIS / lokalni fajl)"
                         Checked="OnModeChanged"/>
            <TextBlock Text="Preuzima jednu georeferenciranu sliku ili umece lokalni GeoTIFF/world-file."
                       TextWrapping="Wrap" Foreground="#666" Margin="22,0,0,0" FontSize="11"/>
          </StackPanel>
        </GroupBox>

        <GroupBox x:Name="AutodeskGroup" Header="Autodesk / Esri" Padding="10" Margin="0,0,0,10">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="160"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Text="Stil mape:" VerticalAlignment="Center" Margin="0,0,8,8"/>
            <ComboBox Grid.Column="1" x:Name="MapStyleBox" Height="26" Margin="0,0,0,8"
                      SelectedIndex="0">
              <ComboBoxItem Content="Esri Imagery (satelit)" Tag="EsriImagery"/>
              <ComboBoxItem Content="Esri Streets" Tag="EsriStreets"/>
              <ComboBoxItem Content="Esri OpenStreetMap" Tag="EsriOsm"/>
              <ComboBoxItem Content="Bing Aerial (starije verzije)" Tag="BingAerial"/>
              <ComboBoxItem Content="Bing Hybrid (starije verzije)" Tag="BingHybrid"/>
              <ComboBoxItem Content="Iskljuci mapu" Tag="Off"/>
            </ComboBox>
            <TextBlock Grid.Row="1" Text="Akcija:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ComboBox Grid.Row="1" Grid.Column="1" x:Name="AutodeskActionBox" Height="26" SelectedIndex="1">
              <ComboBoxItem Content="Prikazi uzivo u viewportu" Tag="Live"/>
              <ComboBoxItem Content="Ugradi trenutni viewport u DWG" Tag="CaptureViewport"/>
              <ComboBoxItem Content="Ugradi pravougaonu oblast u DWG" Tag="CaptureArea"/>
            </ComboBox>
          </Grid>
        </GroupBox>

        <GroupBox x:Name="ExternalGroup" Header="Nezavisna podloga" Padding="10" Margin="0,0,0,10" Visibility="Collapsed">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="160"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Izvor:" VerticalAlignment="Center" Margin="0,0,8,8"/>
            <ComboBox Grid.Column="1" x:Name="ExternalSourceBox" Height="26" Margin="0,0,0,8"
                      SelectedIndex="0" SelectionChanged="OnExternalSourceChanged">
              <ComboBoxItem Content="ArcGIS World Imagery (Esri)" Tag="ArcGisWorld"/>
              <ComboBoxItem Content="Prilagodjeni WMS / ArcGIS URL" Tag="CustomUrl"/>
              <ComboBoxItem Content="Lokalni GeoTIFF / JPG / PNG" Tag="LocalFile"/>
            </ComboBox>

            <TextBlock Grid.Row="1" Text="CRS crteza:" VerticalAlignment="Center" Margin="0,0,8,8"/>
            <ComboBox Grid.Row="1" Grid.Column="1" x:Name="CrsBox" Height="26" Margin="0,0,0,8" SelectedIndex="0"
                      ToolTip="Kako se X/Y koordinate crteza pretvaraju u geografske — bez potrebe za AutoCAD geolokacijom">
              <ComboBoxItem Content="Automatski — Gauss-Krüger (zona iz Y)" Tag="AutoGk"/>
              <ComboBoxItem Content="Gauss-Krüger zona 5 (CM 15°)" Tag="Gk5"/>
              <ComboBoxItem Content="Gauss-Krüger zona 6 (CM 18°)" Tag="Gk6"/>
              <ComboBoxItem Content="Gauss-Krüger zona 7 (CM 21°)" Tag="Gk7"/>
              <ComboBoxItem Content="UTM 34N (WGS84)" Tag="Utm34N"/>
              <ComboBoxItem Content="AutoCAD geolokacija crteza" Tag="AcadGeo"/>
            </ComboBox>

            <TextBlock Grid.Row="2" Text="URL servisa:" VerticalAlignment="Center" Margin="0,0,8,8"/>
            <TextBox Grid.Row="2" Grid.Column="1" x:Name="ServiceUrlBox" Height="26" Margin="0,0,0,8"
                     Text="https://services.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer"/>

            <TextBlock Grid.Row="3" Text="WMS lejer (opciono):" VerticalAlignment="Center" Margin="0,0,8,8"/>
            <TextBox Grid.Row="3" Grid.Column="1" x:Name="WmsLayerBox" Height="26" Margin="0,0,0,8"/>

            <TextBlock Grid.Row="4" Text="Lokalni fajl:" VerticalAlignment="Center" Margin="0,0,8,8"/>
            <Grid Grid.Row="4" Grid.Column="1" Margin="0,0,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <TextBox x:Name="LocalFileBox" Height="26" IsReadOnly="True"/>
              <Button Grid.Column="1" Content="…" Width="32" Height="26" Margin="6,0,0,0" Click="OnBrowseFile"/>
            </Grid>

            <TextBlock Grid.Row="5" Text="Oblast:" VerticalAlignment="Center" Margin="0,0,8,8"/>
            <ComboBox Grid.Row="5" Grid.Column="1" x:Name="AreaModeBox" Height="26" Margin="0,0,0,8" SelectedIndex="0">
              <ComboBoxItem Content="Oznaci pravougaonik u crtezu" Tag="Pick"/>
              <ComboBoxItem Content="Trenutni viewport" Tag="Viewport"/>
            </ComboBox>

            <TextBlock Grid.Row="6" Text="Rezolucija (px):" VerticalAlignment="Center" Margin="0,0,8,8"/>
            <ComboBox Grid.Row="6" Grid.Column="1" x:Name="ResolutionBox" Height="26" Margin="0,0,0,8" SelectedIndex="1">
              <ComboBoxItem Content="1024" Tag="1024"/>
              <ComboBoxItem Content="2048" Tag="2048"/>
              <ComboBoxItem Content="4096" Tag="4096"/>
            </ComboBox>

            <TextBlock Grid.Row="7" Text="Providnost (%):" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <StackPanel Grid.Row="7" Grid.Column="1" Orientation="Horizontal">
              <Slider x:Name="OpacitySlider" Minimum="20" Maximum="100" Value="85" Width="180"
                      VerticalAlignment="Center" TickFrequency="5" IsSnapToTickEnabled="True"/>
              <TextBlock x:Name="OpacityLabel" Text="85%" VerticalAlignment="Center" Margin="10,0,0,0" Width="40"/>
            </StackPanel>
          </Grid>
        </GroupBox>
      </StackPanel>
    </ScrollViewer>

    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
      <Button Content="Nastavi" Width="110" Height="30" IsDefault="True" Click="OnAccept" Margin="0,0,8,0"/>
      <Button Content="Odustani" Width="96" Height="30" IsCancel="True"/>
    </StackPanel>
  </Grid>
</Window>
