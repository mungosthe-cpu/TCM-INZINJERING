<Window x:Class="TcmInzenjering.Plugin.Dialogs.TerrainVolumeConfidenceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TCM-ROADS — Zapremina, panel poverenja"
        Width="720" Height="640"
        MinWidth="640" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False"
        Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
  <Grid Margin="14">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <GroupBox Grid.Row="0" Header="Terenni" Margin="0,0,0,10" Padding="8">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Baza (postojece):" VerticalAlignment="Center" Margin="0,0,8,8"/>
        <ComboBox Grid.Column="1" x:Name="BaseBox" Height="28" Margin="0,0,12,8"
                  IsEditable="False"/>
        <TextBlock Grid.Column="2" Text="Poredjenje (projekat):" VerticalAlignment="Center" Margin="0,0,8,8"/>
        <ComboBox Grid.Column="3" x:Name="ComparisonBox" Height="28" Margin="0,0,0,8"
                  IsEditable="False"/>
        <TextBlock Grid.Row="1" Text="Granica AOI:" VerticalAlignment="Center" Margin="0,0,8,0"/>
        <ComboBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" x:Name="BoundModeBox"
                  Height="28" SelectedIndex="0">
          <ComboBoxItem Content="Overlap dva terena"/>
          <ComboBoxItem Content="Izaberi zatvorenu poliliniju"/>
        </ComboBox>
      </Grid>
    </GroupBox>

    <GroupBox Grid.Row="1" Header="Parametri" Margin="0,0,0,10" Padding="8">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="90"/>
          <ColumnDefinition Width="16"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="70"/>
          <ColumnDefinition Width="16"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="70"/>
          <ColumnDefinition Width="16"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="70"/>
        </Grid.ColumnDefinitions>
        <TextBlock Text="Grid korak (m):" VerticalAlignment="Center" Margin="0,0,6,0"/>
        <TextBox Grid.Column="1" x:Name="GridStepBox" Text="5" Height="28"
                 VerticalContentAlignment="Center"/>
        <TextBlock Grid.Column="3" Text="Sekcije:" VerticalAlignment="Center" Margin="0,0,6,0"/>
        <TextBox Grid.Column="4" x:Name="SectionCountBox" Text="12" Height="28"
                 VerticalContentAlignment="Center"/>
        <TextBlock Grid.Column="6" Text="Nabujavanje (iskop):" VerticalAlignment="Center" Margin="0,0,6,0"/>
        <TextBox Grid.Column="7" x:Name="SwellBox" Text="1.00" Height="28"
                 VerticalContentAlignment="Center"
                 ToolTip="Faktor nabujavanja (swell) za iskop, npr. 1.25"/>
        <TextBlock Grid.Column="9" Text="Sleganje (nasip):" VerticalAlignment="Center" Margin="0,0,6,0"/>
        <TextBox Grid.Column="10" x:Name="ShrinkBox" Text="1.00" Height="28"
                 VerticalContentAlignment="Center"
                 ToolTip="Faktor sleganja (shrink) za nasip, npr. 0.90"/>
      </Grid>
    </GroupBox>

    <GroupBox Grid.Row="2" Header="Rezultati (m³)" Padding="8">
      <DockPanel>
        <Border x:Name="ConfidenceBanner" DockPanel.Dock="Top" Padding="8,6" Margin="0,0,0,8"
                Background="#E8F5E9" BorderBrush="#A5D6A7" BorderThickness="1" CornerRadius="3">
          <TextBlock x:Name="ConfidenceText" TextWrapping="Wrap"
                     Text="Izracunajte zapreminu da vidite panel poverenja."/>
        </Border>
        <DataGrid x:Name="ResultsGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  ScrollViewer.VerticalScrollBarVisibility="Auto">
          <DataGrid.Columns>
            <DataGridTextColumn Header="Metoda" Binding="{Binding Method}" Width="100"/>
            <DataGridTextColumn Header="Iskop" Binding="{Binding Cut}" Width="*"/>
            <DataGridTextColumn Header="Nasip" Binding="{Binding Fill}" Width="*"/>
            <DataGridTextColumn Header="Neto" Binding="{Binding Net}" Width="*"/>
            <DataGridTextColumn Header="Pov. iskop" Binding="{Binding CutArea}" Width="*"/>
            <DataGridTextColumn Header="Pov. nasip" Binding="{Binding FillArea}" Width="*"/>
          </DataGrid.Columns>
        </DataGrid>
      </DockPanel>
    </GroupBox>

    <TextBlock Grid.Row="3" x:Name="DetailText" TextWrapping="Wrap" Margin="0,8,0,0"
               Foreground="#444" FontSize="12"/>

    <DockPanel Grid.Row="4" Margin="0,12,0,0" LastChildFill="False">
      <Button DockPanel.Dock="Left" Content="Izracunaj" Width="110" Height="30"
              Margin="0,0,8,0" IsDefault="True" Click="OnCalculate"/>
      <Button DockPanel.Dock="Left" Content="Prikazi mapu" Width="120" Height="30"
              Margin="0,0,8,0" Click="OnShowMap"/>
      <Button DockPanel.Dock="Left" Content="Snimi izvestaj" Width="120" Height="30"
              Margin="0,0,8,0" Click="OnSaveReport"/>
      <Button DockPanel.Dock="Right" Content="Zatvori" Width="100" Height="30"
              IsCancel="True" Click="OnClose"/>
    </DockPanel>
  </Grid>
</Window>
