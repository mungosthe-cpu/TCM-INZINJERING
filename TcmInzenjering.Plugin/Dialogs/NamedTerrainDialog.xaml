<Window x:Class="TcmInzenjering.Plugin.Dialogs.NamedTerrainDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ime terena"
        Width="440"
        SizeToContent="Height"
        MinHeight="240"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" TextWrapping="Wrap" Margin="0,0,0,12"
               Text="Unesite ime terena (kao Civil Surface). Kasnije ga mozete ucitati / azurirati po imenu."/>

    <Grid Grid.Row="1" Margin="0,0,0,10">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="90"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>
      <TextBlock Text="Ime terena:" VerticalAlignment="Center"/>
      <ComboBox Grid.Column="1" x:Name="NameBox" Height="28" IsEditable="True"
                IsTextSearchEnabled="True"/>
    </Grid>

    <TextBlock Grid.Row="2" x:Name="HintText" Margin="0,0,0,16" Foreground="#666"
               TextWrapping="Wrap" MinHeight="32"/>

    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
      <Button Content="OK" Width="96" Height="28" IsDefault="True" Click="OnOk" Margin="0,0,8,0"/>
      <Button Content="Odustani" Width="96" Height="28" IsCancel="True" Click="OnCancel"/>
    </StackPanel>
  </Grid>
</Window>
