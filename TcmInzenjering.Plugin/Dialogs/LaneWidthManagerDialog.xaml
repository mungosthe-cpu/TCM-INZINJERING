<Window x:Class="TcmInzenjering.Plugin.Dialogs.LaneWidthManagerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TcmInzenjering.Plugin.Dialogs"
        Title="TCM-ROADS — Upravljanje trakama"
        Width="1180"
        Height="780"
        MinWidth="980"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Background="#F4F6F9">
    <Window.Resources>
        <local:FlexibleDoubleConverter x:Key="FlexDouble"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#1B6FDB"/>
        <SolidColorBrush x:Key="AccentDarkBrush" Color="#1259B8"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#D64545"/>
        <SolidColorBrush x:Key="GreenBrush" Color="#1E9E56"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#E1E6EE"/>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style x:Key="CardTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#3C4657"/>
            <Setter Property="Margin" Value="12,8,12,6"/>
        </Style>
        <Style x:Key="BaseButton" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BlueOutlineButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="#F3F8FF"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource AccentDarkBrush}"/>
        </Style>
        <Style x:Key="RedOutlineButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="#FFF6F6"/>
            <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
        </Style>
        <Style x:Key="GrayOutlineButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#C9D1DD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#3C4657"/>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentDarkBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="ArrowButton" TargetType="Button" BasedOn="{StaticResource BlueOutlineButton}">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style x:Key="LaneGrid" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#EDF0F5"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowHeight" Value="28"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="2,0,0,8">
            <TextBlock Text="Nativ ose:" FontSize="14" FontWeight="SemiBold" Foreground="#3C4657"/>
            <TextBlock x:Name="AxisNameText" FontSize="14" FontWeight="Bold"
                       Foreground="{StaticResource AccentDarkBrush}" Margin="10,0,0,0"/>
        </StackPanel>

        <TabControl Grid.Row="1" x:Name="MainTabs" Margin="0,0,0,10">
            <!-- Tipovi -->
            <TabItem Header="Tipovi">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="220"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Definisani tipovi" Style="{StaticResource CardTitle}"/>
                                <ComboBox x:Name="TypeBox" Height="28" Margin="12,0,12,0"
                                          IsEditable="True" SelectionChanged="OnTypeSelectionChanged"/>
                                <ComboBox x:Name="TemplateBox" Height="28" Margin="12,8,12,0"
                                          SelectionChanged="OnTemplateSelected"/>
                                <Button Content="SNIMI TIP" Style="{StaticResource BlueOutlineButton}"
                                        Margin="12,10,12,0" Click="OnSaveType"/>
                                <Button Content="OGLEDALO L↔D" Style="{StaticResource GrayOutlineButton}"
                                        Margin="12,8,12,0" Click="OnMirror"/>
                                <Button Content="BRIŠI TIP" Style="{StaticResource RedOutlineButton}"
                                        Margin="12,8,12,0" Click="OnDeleteType"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Style="{StaticResource Card}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock x:Name="PreviewTitleText" Style="{StaticResource CardTitle}"
                                           Text="Poprečni prikaz"/>
                                <Canvas x:Name="PreviewCanvas" Grid.Row="1" Margin="8"
                                        SizeChanged="OnPreviewSizeChanged"/>
                            </Grid>
                        </Border>
                    </Grid>
                    <Border Grid.Row="1" Style="{StaticResource Card}">
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="LEVO" FontWeight="Bold" Foreground="{StaticResource AccentDarkBrush}"/>
                                <DataGrid x:Name="LeftGrid" Grid.Row="1" Style="{StaticResource LaneGrid}"
                                          Margin="0,6,0,0" CellEditEnding="OnGridCellEditEnding">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Oznaka" Binding="{Binding Label, UpdateSourceTrigger=LostFocus}" Width="*"/>
                                        <DataGridTextColumn Header="Širina" Binding="{Binding Width, UpdateSourceTrigger=LostFocus, Converter={StaticResource FlexDouble}}" Width="80"/>
                                        <DataGridCheckBoxColumn Header="Kolovoz" Binding="{Binding IsCarriageway, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                                    <Button Content="＋ DODAJ" Style="{StaticResource BlueOutlineButton}" Click="OnAddLeft"/>
                                    <Button Content="BRIŠI" Style="{StaticResource RedOutlineButton}" Margin="8,0,0,0" Click="OnDeleteLeft"/>
                                    <Button Content="↑" Style="{StaticResource ArrowButton}" Margin="16,0,0,0" Click="OnMoveLeftUp"/>
                                    <Button Content="↓" Style="{StaticResource ArrowButton}" Margin="6,0,0,0" Click="OnMoveLeftDown"/>
                                </StackPanel>
                            </Grid>
                            <Grid Grid.Column="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="DESNO" FontWeight="Bold" Foreground="{StaticResource GreenBrush}"/>
                                <DataGrid x:Name="RightGrid" Grid.Row="1" Style="{StaticResource LaneGrid}"
                                          Margin="0,6,0,0" CellEditEnding="OnGridCellEditEnding">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Oznaka" Binding="{Binding Label, UpdateSourceTrigger=LostFocus}" Width="*"/>
                                        <DataGridTextColumn Header="Širina" Binding="{Binding Width, UpdateSourceTrigger=LostFocus, Converter={StaticResource FlexDouble}}" Width="80"/>
                                        <DataGridCheckBoxColumn Header="Kolovoz" Binding="{Binding IsCarriageway, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                                    <Button Content="＋ DODAJ" Style="{StaticResource BlueOutlineButton}" Click="OnAddRight"/>
                                    <Button Content="BRIŠI" Style="{StaticResource RedOutlineButton}" Margin="8,0,0,0" Click="OnDeleteRight"/>
                                    <Button Content="↑" Style="{StaticResource ArrowButton}" Margin="16,0,0,0" Click="OnMoveRightUp"/>
                                    <Button Content="↓" Style="{StaticResource ArrowButton}" Margin="6,0,0,0" Click="OnMoveRightDown"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Po stacionaži -->
            <TabItem Header="Po stacionaži">
                <Border Style="{StaticResource Card}" Margin="8">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Kontrolne tačke širine (linearna interpolacija)" Style="{StaticResource CardTitle}" Margin="0,0,0,8"/>
                        <DataGrid x:Name="PointsGrid" Grid.Row="1" Style="{StaticResource LaneGrid}"
                                  CellEditEnding="OnPointsEditEnding">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Stacionaža" Binding="{Binding Station, UpdateSourceTrigger=LostFocus, Converter={StaticResource FlexDouble}}" Width="120"/>
                                <DataGridTextColumn Header="Traka (Id)" Binding="{Binding LaneId, UpdateSourceTrigger=LostFocus}" Width="120"/>
                                <DataGridTextColumn Header="Oznaka" Binding="{Binding Label, UpdateSourceTrigger=LostFocus}" Width="*"/>
                                <DataGridTextColumn Header="Širina [m]" Binding="{Binding Width, UpdateSourceTrigger=LostFocus, Converter={StaticResource FlexDouble}}" Width="110"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
                            <Button Content="＋ DODAJ" Style="{StaticResource BlueOutlineButton}" Click="OnAddPoint"/>
                            <Button Content="BRIŠI" Style="{StaticResource RedOutlineButton}" Margin="8,0,0,0" Click="OnDeletePoint"/>
                            <Button Content="✕ Iz crteža" Style="{StaticResource GrayOutlineButton}" Margin="8,0,0,0" Click="OnPickPointStation"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </TabItem>

            <!-- Segmenti -->
            <TabItem Header="Segmenti tipova">
                <Border Style="{StaticResource Card}" Margin="8">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Tip kolovoza po opsegu stacionaže" Style="{StaticResource CardTitle}" Margin="0,0,0,8"/>
                        <DataGrid x:Name="AssignmentsGrid" Grid.Row="1" Style="{StaticResource LaneGrid}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Od STA" Binding="{Binding StartStation, UpdateSourceTrigger=LostFocus, Converter={StaticResource FlexDouble}}" Width="120"/>
                                <DataGridTextColumn Header="Do STA" Binding="{Binding EndStation, UpdateSourceTrigger=LostFocus, Converter={StaticResource FlexDouble}}" Width="120"/>
                                <DataGridTextColumn Header="Tip" Binding="{Binding TypeName, UpdateSourceTrigger=LostFocus}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
                            <Button Content="＋ DODAJ" Style="{StaticResource BlueOutlineButton}" Click="OnAddAssignment"/>
                            <Button Content="BRIŠI" Style="{StaticResource RedOutlineButton}" Margin="8,0,0,0" Click="OnDeleteAssignment"/>
                            <Button Content="✕ Od" Style="{StaticResource GrayOutlineButton}" Margin="8,0,0,0" Click="OnPickSegmentStart"/>
                            <Button Content="✕ Do" Style="{StaticResource GrayOutlineButton}" Margin="8,0,0,0" Click="OnPickSegmentEnd"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </TabItem>

            <!-- Proširenje -->
            <TabItem Header="Proširenje">
                <Border Style="{StaticResource Card}" Margin="8">
                    <StackPanel Margin="16">
                        <CheckBox x:Name="WideningEnabledBox" Content="Automatsko proširenje u krivinama (R + V)"
                                  FontWeight="SemiBold" Margin="0,0,0,14"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="140"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Projektna brzina V [km/h]" VerticalAlignment="Center"/>
                            <TextBox x:Name="SpeedBox" Grid.Column="1" Height="28" Margin="0,0,0,8"/>
                            <TextBlock Grid.Row="1" Text="Ručna korekcija L [m]" VerticalAlignment="Center"/>
                            <TextBox x:Name="ManualLeftBox" Grid.Row="1" Grid.Column="1" Height="28" Margin="0,0,0,8"/>
                            <TextBlock Grid.Row="2" Text="Ručna korekcija D [m]" VerticalAlignment="Center"/>
                            <TextBox x:Name="ManualRightBox" Grid.Row="2" Grid.Column="1" Height="28" Margin="0,0,0,8"/>
                            <TextBlock Grid.Row="3" Text="Dužina prelaza [m]" VerticalAlignment="Center"/>
                            <TextBox x:Name="TransitionBox" Grid.Row="3" Grid.Column="1" Height="28"/>
                        </Grid>
                        <TextBlock Margin="0,14,0,0" Foreground="#7A8494" TextWrapping="Wrap"
                                   Text="Δb ≈ L²/(2R) skalirano brzinom, sa linearnim prelazom pre/posle luka. Dodaje se spoljnoj kolovoznoj traci."/>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- Šrafura -->
            <TabItem Header="Šrafura">
                <Border Style="{StaticResource Card}" Margin="8">
                    <StackPanel Margin="16">
                        <CheckBox x:Name="DrawBoundariesBox" Content="Crtaj unutrašnje granice traka"
                                  FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <CheckBox x:Name="HatchEnabledBox" Content="Crtaj šrafuru kolovoza"
                                  FontWeight="SemiBold" Margin="0,0,0,14"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="180"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Pattern" VerticalAlignment="Center"/>
                            <ComboBox x:Name="HatchPatternBox" Grid.Column="1" Height="28" Margin="0,0,0,8">
                                <ComboBoxItem Content="ANSI31" IsSelected="True"/>
                                <ComboBoxItem Content="ANSI32"/>
                                <ComboBoxItem Content="SOLID"/>
                                <ComboBoxItem Content="AR-SAND"/>
                            </ComboBox>
                            <TextBlock Grid.Row="1" Text="Skala" VerticalAlignment="Center"/>
                            <TextBox x:Name="HatchScaleBox" Grid.Row="1" Grid.Column="1" Height="28" Margin="0,0,0,8"/>
                            <TextBlock Grid.Row="2" Text="Ugao [°]" VerticalAlignment="Center"/>
                            <TextBox x:Name="HatchAngleBox" Grid.Row="2" Grid.Column="1" Height="28" Margin="0,0,0,8"/>
                            <TextBlock Grid.Row="3" Text="Boja ACI" VerticalAlignment="Center"/>
                            <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal">
                                <Border x:Name="HatchColorSwatch" Width="28" Height="28" BorderBrush="#C9D1DD" BorderThickness="1" Margin="0,0,8,0"/>
                                <Button Content="Izaberi…" Style="{StaticResource GrayOutlineButton}" Click="OnPickHatchColor"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="✓  OK" Style="{StaticResource PrimaryButton}" Width="150" Height="36"
                    Margin="0,0,14,0" IsDefault="True" Click="OnOk"/>
            <Button Content="✕  CANCEL" Style="{StaticResource GrayOutlineButton}" Width="150" Height="36"
                    IsCancel="True" Click="OnCancel"/>
        </StackPanel>
    </Grid>
</Window>
