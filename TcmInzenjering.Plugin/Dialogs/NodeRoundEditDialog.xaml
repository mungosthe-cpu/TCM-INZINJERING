<Window x:Class="TcmInzenjering.Plugin.Dialogs.NodeRoundEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Uređenje krivine"
        SizeToContent="Height"
        Width="580"
        MinHeight="650"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#F5F7FA">
  <Window.Resources>
    <Style x:Key="Card" TargetType="Border">
      <Setter Property="Background" Value="White"/>
      <Setter Property="BorderBrush" Value="#DCE2EA"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="10"/>
    </Style>
    <Style TargetType="TextBox">
      <Setter Property="Height" Value="28"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="Padding" Value="6,0"/>
      <Setter Property="BorderBrush" Value="#CBD3DE"/>
    </Style>
    <Style TargetType="ComboBox">
      <Setter Property="Height" Value="28"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
    <Style TargetType="Button">
      <Setter Property="Height" Value="34"/>
      <Setter Property="Padding" Value="12,0"/>
      <Setter Property="FontSize" Value="12"/>
    </Style>
    <Style x:Key="PickButton" TargetType="Button">
      <Setter Property="Width" Value="32"/>
      <Setter Property="Height" Value="28"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Foreground" Value="#D63C32"/>
      <Setter Property="Background" Value="White"/>
      <Setter Property="BorderBrush" Value="#D8DEE7"/>
      <Setter Property="FontSize" Value="15"/>
    </Style>
  </Window.Resources>

  <Grid Margin="14">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <Grid Grid.Row="0" Margin="0,0,0,10">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="1.55*"/>
        <ColumnDefinition Width="1*"/>
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0">
        <StackPanel>
          <TextBlock Text="PREGLED KRIVINE" Foreground="#24568F" FontWeight="Bold" Margin="0,0,0,6"/>
          <Viewbox Height="200" Stretch="Uniform">
            <Canvas Width="520" Height="330" Background="White">
              <Line X1="260" Y1="30" X2="45" Y2="300" Stroke="#333A42" StrokeThickness="3"/>
              <Line X1="260" Y1="30" X2="475" Y2="300" Stroke="#333A42" StrokeThickness="3"/>
              <Path Data="M 112,220 Q 260,87 408,220"
                    Stroke="#DDF3FC" StrokeThickness="30" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
              <Path Data="M 112,220 Q 260,87 408,220"
                    Stroke="#109FDF" StrokeThickness="4" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
              <Line X1="260" Y1="41" X2="260" Y2="125" Stroke="#1769C2" StrokeThickness="3"/>
              <Polygon Points="260,41 252,56 268,56" Fill="#1769C2"/>
              <Ellipse Canvas.Left="249" Canvas.Top="19" Width="22" Height="22" Fill="White" Stroke="#16913B" StrokeThickness="5"/>
              <Ellipse Canvas.Left="35" Canvas.Top="289" Width="22" Height="22" Fill="White" Stroke="#16913B" StrokeThickness="5"/>
              <Ellipse Canvas.Left="464" Canvas.Top="289" Width="22" Height="22" Fill="White" Stroke="#16913B" StrokeThickness="5"/>
              <TextBlock Canvas.Left="238" Canvas.Top="0" Text="TS 1" Foreground="#11852E" FontSize="19" FontWeight="Bold"/>
              <TextBlock Canvas.Left="16" Canvas.Top="307" Text="TS 0" Foreground="#11852E" FontSize="19" FontWeight="Bold"/>
              <TextBlock Canvas.Left="458" Canvas.Top="307" Text="TS 2" Foreground="#11852E" FontSize="19" FontWeight="Bold"/>
              <TextBlock Canvas.Left="250" Canvas.Top="75" Text="R" Foreground="#1769C2" FontSize="24" FontWeight="Bold"/>
              <TextBlock Canvas.Left="76" Canvas.Top="102" Text="r_L" Foreground="#1769C2" FontSize="22" FontWeight="Bold"/>
              <TextBlock Canvas.Left="410" Canvas.Top="102" Text="r_R" Foreground="#1769C2" FontSize="22" FontWeight="Bold"/>
              <TextBlock Canvas.Left="130" Canvas.Top="214" Text="L1 (A1)" Foreground="#1769C2" FontSize="18" FontWeight="Bold"/>
              <TextBlock Canvas.Left="322" Canvas.Top="214" Text="L2 (A2)" Foreground="#1769C2" FontSize="18" FontWeight="Bold"/>
              <TextBlock Canvas.Left="100" Canvas.Top="260" Text="R1" Foreground="#1769C2" FontSize="18" FontWeight="Bold"/>
              <TextBlock Canvas.Left="397" Canvas.Top="260" Text="R2" Foreground="#1769C2" FontSize="18" FontWeight="Bold"/>
            </Canvas>
          </Viewbox>
        </StackPanel>
      </Border>

      <Border Grid.Column="1" Style="{StaticResource Card}">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <TextBlock Text="TIP" Foreground="#24568F" FontWeight="Bold" Margin="0,0,0,14"/>
          <RadioButton x:Name="AutoRadio" Grid.Row="1" Content="Auto" IsChecked="True"
                       Margin="4,0,0,13" Checked="OnTipChanged"/>
          <RadioButton x:Name="ManualRadio" Grid.Row="2" Content="Ručni"
                       Margin="4,0,0,10" Checked="OnTipChanged"/>
          <Grid Grid.Row="3" Margin="4,0,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="48"/>
            </Grid.ColumnDefinitions>
            <ComboBox x:Name="ManualModeBox" Margin="0,0,9,0"
                      SelectionChanged="OnManualModeChanged">
              <ComboBoxItem Content="LRL" IsSelected="True"/>
              <ComboBoxItem Content="LR"/>
              <ComboBoxItem Content="RL"/>
              <ComboBoxItem Content="LL"/>
            </ComboBox>
            <Button x:Name="ParamABtn" Grid.Column="1" Content="L"
                    ToolTip="Prebaci prikaz parametara prelaznice A ↔ L"
                    Click="OnParamAClick"/>
          </Grid>
          <Button x:Name="RefreshBtn" Grid.Row="4" Content="⟳  Osveži"
                  Margin="4,18,0,0" Click="OnRefreshClick"
                  Foreground="#245F9E"/>
        </Grid>
      </Border>
    </Grid>

    <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,10">
      <StackPanel>
        <TextBlock Text="PARAMETRI KRIVINE" Foreground="#24568F" FontWeight="Bold" Margin="0,0,0,8"/>
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="38"/>
            <ColumnDefinition Width="55"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="32"/>
            <ColumnDefinition Width="46"/>
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="34"/><RowDefinition Height="34"/><RowDefinition Height="34"/>
            <RowDefinition Height="34"/><RowDefinition Height="34"/><RowDefinition Height="34"/>
            <RowDefinition Height="34"/>
          </Grid.RowDefinitions>

          <CheckBox x:Name="R1Lock" Grid.Row="0" VerticalAlignment="Center" Checked="OnTipChanged" Unchecked="OnTipChanged"/>
          <TextBlock Grid.Row="0" Grid.Column="1" Text="R1" VerticalAlignment="Center" FontWeight="SemiBold"/>
          <TextBox x:Name="R1Box" Grid.Row="0" Grid.Column="2" Text="0.0"/>
          <TextBlock Grid.Row="0" Grid.Column="3" Text="m" VerticalAlignment="Center" HorizontalAlignment="Center"/>

          <CheckBox x:Name="L1Lock" Grid.Row="1" VerticalAlignment="Center" Checked="OnTipChanged" Unchecked="OnTipChanged"/>
          <TextBlock x:Name="L1Label" Grid.Row="1" Grid.Column="1" Text="L1" VerticalAlignment="Center" FontWeight="SemiBold"/>
          <TextBox x:Name="L1Box" Grid.Row="1" Grid.Column="2" Text="0.0" TextChanged="OnParamChanged"/>
          <TextBlock Grid.Row="1" Grid.Column="3" Text="m" VerticalAlignment="Center" HorizontalAlignment="Center"/>

          <CheckBox x:Name="RLock" Grid.Row="2" VerticalAlignment="Center" Checked="OnTipChanged" Unchecked="OnTipChanged"/>
          <TextBlock Grid.Row="2" Grid.Column="1" Text="R" VerticalAlignment="Center" FontWeight="SemiBold"/>
          <TextBox x:Name="RBox" Grid.Row="2" Grid.Column="2" TextChanged="OnParamChanged"/>
          <TextBlock Grid.Row="2" Grid.Column="3" Text="m" VerticalAlignment="Center" HorizontalAlignment="Center"/>
          <Button Grid.Row="2" Grid.Column="4" Style="{StaticResource PickButton}" Content="×" Click="OnPickR"
                  ToolTip="Iz crteža odredite R"/>

          <CheckBox x:Name="L2Lock" Grid.Row="3" VerticalAlignment="Center" Checked="OnTipChanged" Unchecked="OnTipChanged"/>
          <TextBlock x:Name="L2Label" Grid.Row="3" Grid.Column="1" Text="L2" VerticalAlignment="Center" FontWeight="SemiBold"/>
          <TextBox x:Name="L2Box" Grid.Row="3" Grid.Column="2" Text="0.0" TextChanged="OnParamChanged"/>
          <TextBlock Grid.Row="3" Grid.Column="3" Text="m" VerticalAlignment="Center" HorizontalAlignment="Center"/>

          <CheckBox x:Name="R2Lock" Grid.Row="4" VerticalAlignment="Center" Checked="OnTipChanged" Unchecked="OnTipChanged"/>
          <TextBlock Grid.Row="4" Grid.Column="1" Text="R2" VerticalAlignment="Center" FontWeight="SemiBold"/>
          <TextBox x:Name="R2Box" Grid.Row="4" Grid.Column="2" Text="0.0"/>
          <TextBlock Grid.Row="4" Grid.Column="3" Text="m" VerticalAlignment="Center" HorizontalAlignment="Center"/>

          <CheckBox x:Name="RlLock" Grid.Row="5" VerticalAlignment="Center" Checked="OnTipChanged" Unchecked="OnTipChanged"/>
          <TextBlock Grid.Row="5" Grid.Column="1" Text="rL" VerticalAlignment="Center" FontWeight="SemiBold"/>
          <TextBox x:Name="RlBox" Grid.Row="5" Grid.Column="2" TextChanged="OnParamChanged"/>
          <TextBlock Grid.Row="5" Grid.Column="3" Text="m" VerticalAlignment="Center" HorizontalAlignment="Center"/>
          <Button Grid.Row="5" Grid.Column="4" Style="{StaticResource PickButton}" Content="×" Click="OnPickRl"
                  ToolTip="Iz crteža odredite rL"/>

          <CheckBox x:Name="RrLock" Grid.Row="6" VerticalAlignment="Center" Checked="OnTipChanged" Unchecked="OnTipChanged"/>
          <TextBlock Grid.Row="6" Grid.Column="1" Text="rR" VerticalAlignment="Center" FontWeight="SemiBold"/>
          <TextBox x:Name="RrBox" Grid.Row="6" Grid.Column="2" TextChanged="OnParamChanged"/>
          <TextBlock Grid.Row="6" Grid.Column="3" Text="m" VerticalAlignment="Center" HorizontalAlignment="Center"/>
          <Button Grid.Row="6" Grid.Column="4" Style="{StaticResource PickButton}" Content="×" Click="OnPickRr"
                  ToolTip="Iz crteža odredite rR"/>
        </Grid>
      </StackPanel>
    </Border>

    <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,0,0,12">
      <StackPanel>
        <TextBlock Text="PARAMETRI AUTOMATSKE OPCIJE" Foreground="#24568F" FontWeight="Bold" Margin="0,0,0,8"/>
        <StackPanel Orientation="Horizontal">
          <CheckBox x:Name="PrelazniceBox" Content="Prelaznice" VerticalAlignment="Center"
                    Margin="4,0,24,0" Checked="OnTipChanged" Unchecked="OnTipChanged"/>
          <TextBlock Text="R/A =" VerticalAlignment="Center" Margin="0,0,8,0"/>
          <TextBox x:Name="RaBox" Width="105" Text="2.0" TextChanged="OnRaChanged"/>
        </StackPanel>
      </StackPanel>
    </Border>

    <Grid Grid.Row="3">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <Button Content="✓  OK" Width="115" IsDefault="True" Click="OnOk"
              Background="#1769D2" Foreground="White" BorderBrush="#1769D2"/>
      <StackPanel Grid.Column="1" Orientation="Horizontal">
        <Button x:Name="PrevBtn" Content="❮  Prethodni" Width="105" Margin="0,0,6,0" Click="OnPrev"/>
        <Button x:Name="NextBtn" Content="Sledeći  ❯" Width="105" Margin="0,0,6,0" Click="OnNext"/>
        <Button Content="×  Cancel" Width="95" IsCancel="True" Click="OnCancel"
                Foreground="#B33A32"/>
      </StackPanel>
    </Grid>
  </Grid>
</Window>
