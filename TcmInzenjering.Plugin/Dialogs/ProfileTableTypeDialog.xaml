<Window x:Class="TcmInzenjering.Plugin.Dialogs.ProfileTableTypeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tip tabele"
        Height="520"
        Width="640"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
  <Grid Margin="14">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="170"/>
      <ColumnDefinition Width="12"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <GroupBox Grid.Row="0" Grid.Column="0" Header="Snimljeni tipovi" Padding="8">
      <DockPanel>
        <StackPanel DockPanel.Dock="Bottom" Orientation="Vertical" Margin="0,8,0,0">
          <Button Content="Novi" Height="26" Margin="0,0,0,4" Click="OnNew"/>
          <Button Content="Duplikuj" Height="26" Margin="0,0,0,4" Click="OnDuplicate"/>
          <Button Content="Obrisi" Height="26" Click="OnDelete"/>
        </StackPanel>
        <ListBox x:Name="TypeList" SelectionChanged="OnTypeSelected"/>
      </DockPanel>
    </GroupBox>

    <GroupBox Grid.Row="0" Grid.Column="2" Header="Definicija" Padding="10,8">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,8">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          <TextBlock Text="Naziv tipa" VerticalAlignment="Center" Margin="0,0,8,0"/>
          <TextBox x:Name="NameBox" Grid.Column="1" Height="24"/>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,10">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0">
            <TextBlock Text="Sirina kolone naziva (npr. 50)" Margin="0,0,0,2"/>
            <TextBox x:Name="LabelWidthBox" Height="24"/>
          </StackPanel>
          <StackPanel Grid.Column="2">
            <TextBlock Text="Podraz. visina rubrike (npr. 10)" Margin="0,0,0,2"/>
            <TextBox x:Name="DefaultHeightBox" Height="24"/>
          </StackPanel>
        </Grid>

        <DockPanel Grid.Row="2">
          <TextBlock DockPanel.Dock="Top" Text="Rubrike (od vrha tabele / uz grafik nadole)" Margin="0,0,0,4"/>
          <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
            <Button Content="Dodaj rubriku" Width="110" Height="26" Margin="0,0,6,0" Click="OnAddBand"/>
            <Button Content="Gore" Width="60" Height="26" Margin="0,0,6,0" Click="OnMoveUp"/>
            <Button Content="Dole" Width="60" Height="26" Margin="0,0,6,0" Click="OnMoveDown"/>
            <Button Content="Ukloni" Width="70" Height="26" Click="OnRemoveBand"/>
          </StackPanel>
          <DataGrid x:Name="BandsGrid"
                    AutoGenerateColumns="False"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    HeadersVisibility="Column"
                    SelectionMode="Single"
                    SelectionUnit="FullRow"
                    GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Naslov" Binding="{Binding Title, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
              <DataGridComboBoxColumn Header="Sadrzaj"
                                      SelectedValueBinding="{Binding Content, UpdateSourceTrigger=PropertyChanged}"
                                      SelectedValuePath="Value"
                                      DisplayMemberPath="Label"
                                      Width="160"
                                      x:Name="ContentColumn"/>
              <DataGridTextColumn Header="Visina" Binding="{Binding Height, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
              <DataGridTextColumn Header="Boja ACI" Binding="{Binding TextAci, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
            </DataGrid.Columns>
          </DataGrid>
        </DockPanel>

        <TextBlock Grid.Row="3" FontSize="11" Foreground="#555" TextWrapping="Wrap" Margin="0,8,0,0"
                   Text="Sadrzaj: Oznake, Stacionaze, Kote terena, Kote nivelete (kad VA postoji), Sirine traka L/D (kad kolovoz postoji), Glavni elementi (pravac/luk sa ose). TCM_1 je ugradjeni tip."/>
      </Grid>
    </GroupBox>

    <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
      <Button Content="Snimi" Width="88" Height="28" Margin="0,0,8,0" Click="OnSave"/>
      <Button Content="Primeni" Width="88" Height="28" IsDefault="True" Margin="0,0,8,0" Click="OnApply"/>
      <Button Content="Zatvori" Width="88" Height="28" IsCancel="True" Click="OnClose"/>
    </StackPanel>
  </Grid>
</Window>
