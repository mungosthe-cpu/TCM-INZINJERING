<Window x:Class="TcmInzenjering.Plugin.Dialogs.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Info o programu"
        Height="380"
        Width="440"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="TCM-INZINJERING"
                       FontSize="22"
                       FontWeight="Bold"/>
            <TextBlock x:Name="VersionText"
                       FontSize="13"
                       Foreground="Gray"
                       Margin="0,2,0,0"/>
            <TextBlock Text="AutoCAD/BricsCAD plugin za puteve i osovinsku geometriju"
                       FontSize="12"
                       Margin="0,4,0,0"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <Separator Grid.Row="1" Margin="0,0,0,12"/>

        <GroupBox Grid.Row="2" Header="Autor" Padding="12,10,12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Ime:" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="AuthorText" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Telefon:" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="PhoneText" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="E-mail:" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,0,0,8">
                    <Hyperlink x:Name="EmailLink" Click="OnEmailClick">
                        <TextBlock x:Name="EmailText"/>
                    </Hyperlink>
                </TextBlock>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Facebook:" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,0,0,8">
                    <Hyperlink x:Name="FacebookLink" Click="OnFacebookClick">
                        <TextBlock Text="Dragan Todorović (Ruma)"/>
                    </Hyperlink>
                </TextBlock>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="GitHub:" FontWeight="SemiBold"/>
                <TextBlock Grid.Row="4" Grid.Column="1">
                    <Hyperlink x:Name="GitHubLink" Click="OnGitHubClick">
                        <TextBlock Text="Preuzimanje najnovije verzije"/>
                    </Hyperlink>
                </TextBlock>
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Proveri nadogradnju"
                    Width="150"
                    Height="28"
                    Margin="0,0,8,0"
                    Click="OnCheckUpdate"/>
            <Button Content="Zatvori"
                    Width="90"
                    Height="28"
                    IsDefault="True"
                    IsCancel="True"
                    Click="OnClose"/>
        </StackPanel>
    </Grid>
</Window>
