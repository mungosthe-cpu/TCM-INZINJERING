<Window x:Class="TcmInzenjering.Plugin.Dialogs.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Info o programu"
        Height="540"
        Width="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#0A1A35">
    <Grid ClipToBounds="True">
        <!-- Cela slika u prozoru — bez posebne trake ispod -->
        <Image x:Name="LogoImage"
               Stretch="UniformToFill"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               SnapsToDevicePixels="True"/>

        <!-- Tekst preko donjeg (plavog) dela same slike -->
        <Grid Margin="28,0,28,58" VerticalAlignment="Bottom">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="250"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="TCM-ROADS"
                           Foreground="White"
                           FontSize="20"
                           FontWeight="Bold">
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="5" ShadowDepth="1" Opacity="0.9" Color="Black"/>
                    </TextBlock.Effect>
                </TextBlock>
                <TextBlock x:Name="VersionText"
                           Foreground="White"
                           FontSize="12"
                           Margin="0,2,0,8">
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="5" ShadowDepth="1" Opacity="0.9" Color="Black"/>
                    </TextBlock.Effect>
                </TextBlock>
                <TextBlock Text="AutoCAD / BricsCAD plugin za osovinsku geometriju, stacionaže, poprečne ose i projekciju na teren."
                           Foreground="White"
                           FontSize="12"
                           TextWrapping="Wrap"
                           MaxWidth="460">
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="5" ShadowDepth="1" Opacity="0.9" Color="Black"/>
                    </TextBlock.Effect>
                </TextBlock>
                <TextBlock Margin="0,10,0,2"
                           Foreground="White"
                           FontSize="12">
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="5" ShadowDepth="1" Opacity="0.9" Color="Black"/>
                    </TextBlock.Effect>
                    <Hyperlink x:Name="GitHubLink" Click="OnGitHubClick" Foreground="White" TextDecorations="Underline">
                        Preuzimanje najnovije verzije (GitHub Releases)
                    </Hyperlink>
                </TextBlock>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="Autor"
                           Foreground="White"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6">
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="5" ShadowDepth="1" Opacity="0.9" Color="Black"/>
                    </TextBlock.Effect>
                </TextBlock>
                <TextBlock x:Name="AuthorText" Foreground="White" Margin="0,0,0,4">
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="5" ShadowDepth="1" Opacity="0.9" Color="Black"/>
                    </TextBlock.Effect>
                </TextBlock>
                <TextBlock x:Name="PhoneText" Foreground="White" Margin="0,0,0,4">
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="5" ShadowDepth="1" Opacity="0.9" Color="Black"/>
                    </TextBlock.Effect>
                </TextBlock>
                <TextBlock>
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="5" ShadowDepth="1" Opacity="0.9" Color="Black"/>
                    </TextBlock.Effect>
                    <Hyperlink x:Name="EmailLink" Click="OnEmailClick" Foreground="White" TextDecorations="Underline">
                        <TextBlock x:Name="EmailText" Foreground="White"/>
                    </Hyperlink>
                </TextBlock>
            </StackPanel>
        </Grid>

        <!-- Dugmad preko plavog dela slike (bez crne/plave trake) -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,16,12">
            <Button Content="Proveri nadogradnju"
                    Width="150"
                    Height="28"
                    Margin="0,0,8,0"
                    Click="OnCheckUpdate"/>
            <CheckBox x:Name="CheckOnStartupBox"
                      Content="Pri startu"
                      VerticalAlignment="Center"
                      Margin="0,0,12,0"
                      Foreground="White"
                      ToolTip="Proveravaj nadogradnju pri startu AutoCAD-a"
                      Checked="OnStartupPrefChanged"
                      Unchecked="OnStartupPrefChanged"/>
            <Button Content="Zatvori"
                    Width="90"
                    Height="28"
                    IsDefault="True"
                    IsCancel="True"
                    Click="OnClose"/>
        </StackPanel>
    </Grid>
</Window>
