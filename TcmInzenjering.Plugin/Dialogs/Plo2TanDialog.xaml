<Window x:Class="TcmInzenjering.Plugin.Dialogs.Plo2TanDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Crtanje stacionaža"
        Height="650"
        Width="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Grid.Row="0" Header="Tipovi stacionaže" Padding="10,8,10,10" Margin="0,0,0,8">
            <StackPanel>
                <CheckBox x:Name="EqualIntervalCheck"
                          Content="Na jednakoj razdaljini u granicama:"
                          IsChecked="True"
                          Margin="0,0,0,6"
                          Checked="OnEqualIntervalChanged"
                          Unchecked="OnEqualIntervalChanged"/>

                <StackPanel x:Name="IntervalBoundsPanel" Margin="22,0,0,8">
                    <CheckBox x:Name="WholeIntervalCheck"
                              Content="Po celom intervalu"
                              IsChecked="True"
                              Margin="0,0,0,8"
                              Checked="OnWholeIntervalChanged"
                              Unchecked="OnWholeIntervalChanged"/>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="28"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Početna stacionaža [m]:" VerticalAlignment="Center"/>
                        <TextBox x:Name="StartStationBox"
                                 Grid.Column="1"
                                 Height="22"
                                 VerticalContentAlignment="Center"
                                 Margin="0,0,4,0"
                                 TextChanged="OnStationChanged"/>
                        <Button Grid.Column="2"
                                Content="…"
                                Height="22"
                                Width="26"
                                Padding="0"
                                ToolTip="Bira iz crteža (uskoro)"
                                IsEnabled="False"/>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="28"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Krajnja stacionaža [m]:" VerticalAlignment="Center"/>
                        <TextBox x:Name="EndStationBox"
                                 Grid.Column="1"
                                 Height="22"
                                 VerticalContentAlignment="Center"
                                 Margin="0,0,4,0"
                                 TextChanged="OnStationChanged"/>
                        <Button Grid.Column="2"
                                Content="…"
                                Height="22"
                                Width="26"
                                Padding="0"
                                ToolTip="Bira iz crteža (uskoro)"
                                IsEnabled="False"/>
                    </Grid>

                    <StackPanel x:Name="AlignPanel" Margin="0,0,0,2">
                        <RadioButton x:Name="AlignStartRadio"
                                     Content="Poravnaj sa početnom stacionažom"
                                     IsChecked="True"
                                     Margin="0,0,0,4"
                                     GroupName="Align"/>
                        <RadioButton x:Name="AlignEndRadio"
                                     Content="Poravnaj sa krajnjom stacionažom"
                                     GroupName="Align"/>
                    </StackPanel>
                </StackPanel>

                <CheckBox x:Name="AtStartCheck"
                          Content="U početnoj tački"
                          Margin="0,4,0,4"/>
                <CheckBox x:Name="AtEndCheck"
                          Content="U krajnjoj tački"
                          IsChecked="True"
                          Margin="0,0,0,4"/>
                <CheckBox x:Name="AtMainPointsCheck"
                          Content="U glavnim tačkama"
                          Margin="0,0,0,0"/>
            </StackPanel>
        </GroupBox>

        <GroupBox Grid.Row="1" Header="Parametri osovine i stacionaže" Padding="10,8,10,10" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Ime osovine:" VerticalAlignment="Center" Margin="0,0,8,6"/>
                <TextBox x:Name="AxisNameBox" Grid.Row="0" Grid.Column="1" Height="22" VerticalContentAlignment="Center" Margin="0,0,0,6"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Radijus krivina [m]:" VerticalAlignment="Center" Margin="0,0,8,6"/>
                <TextBox x:Name="RadiusBox" Grid.Row="1" Grid.Column="1" Height="22" VerticalContentAlignment="Center" Margin="0,0,0,6"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Razdaljina između stacionaža [m]:" VerticalAlignment="Center" Margin="0,0,8,6"/>
                <TextBox x:Name="IntervalBox" Grid.Row="2" Grid.Column="1" Height="22" VerticalContentAlignment="Center" Margin="0,0,0,6"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Prefiks oznake stacionaže:" VerticalAlignment="Center" Margin="0,0,8,6"/>
                <TextBox x:Name="PrefixBox" Grid.Row="3" Grid.Column="1" Height="22" VerticalContentAlignment="Center" Margin="0,0,0,6"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Visina teksta [m]:" VerticalAlignment="Center" Margin="0,0,8,6"/>
                <TextBox x:Name="TextHeightBox" Grid.Row="4" Grid.Column="1" Height="22" VerticalContentAlignment="Center" Margin="0,0,0,6"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="Dužina linije stacionaže [m]:" VerticalAlignment="Center" Margin="0,0,8,6"/>
                <TextBox x:Name="TickLengthBox" Grid.Row="5" Grid.Column="1" Height="22" VerticalContentAlignment="Center" Margin="0,0,0,6"/>

                <TextBlock Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2"
                           x:Name="LengthInfo"
                           FontSize="11"
                           Foreground="Gray"
                           TextWrapping="Wrap"/>
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="OK"
                    Width="88"
                    Height="26"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="OnOk"/>
            <Button Content="Otkaži"
                    Width="88"
                    Height="26"
                    IsCancel="True"
                    Click="OnCancel"/>
        </StackPanel>
    </Grid>
</Window>
